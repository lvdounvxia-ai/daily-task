# JZ 短剧模型平台（OpenAI SDK 兼容）
JZ_API_BASE_URL=https://jzapi.duanju.com/v1
JZ_API_KEY=your_jz_api_key

# 裁判模型（可与生成模型相同平台）
JZ_JUDGE_VLM_MODEL=gpt-4o
JZ_JUDGE_TEXT_MODEL=gpt-4o

# 可选：其他 OpenAI 兼容平台
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_VLM_MODEL=gpt-4o
OPENAI_TEXT_MODEL=gpt-4o

# 预留：自定义 HTTP 图片服务
IMAGE_GEN_API_ENDPOINT=
IMAGE_GEN_API_KEY=
